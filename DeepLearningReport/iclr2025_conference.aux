\newlabel{tab:ss_results}{{4}{7}{Semi-Supervised MemN2N test error (\%) on Tasks 16, 17, and 19. \textbf {MemN2N} is the unsupervised baseline from Section~6. \textbf {0\%--50\%} are the mean test errors over 3 runs at each labeling ratio. \textbf {Paper} is the MemN2N PE+LS result from \citet {sukhbaatar2015end}}{table.4}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Semi-supervised training curves for Tasks 16, 17, and 19 at each labeling ratio. Task 16 converges to near-zero error once labeled support exceeds 25\%; Tasks 17 and 19 show no benefit from supervision, reflecting representational and architectural bottlenecks rather than an attentional one.}}{7}{figure.5}\protected@file@percent }
\newlabel{fig:ss}{{5}{7}{Semi-supervised training curves for Tasks 16, 17, and 19 at each labeling ratio. Task 16 converges to near-zero error once labeled support exceeds 25\%; Tasks 17 and 19 show no benefit from supervision, reflecting representational and architectural bottlenecks rather than an attentional one}{figure.5}{}}
\citation{sukhbaatar2015end}
