\newlabel{tab:baseline}{{3}{6}{Test error (\%) on all 20 bAbI tasks. \textbf {Ours (MemN2N)} is our re-implementation; \textbf {Ours (LSTM)} is our bidirectional LSTM reference. \textbf {Paper M} and \textbf {Paper L} are the MemN2N and LSTM results from \citet {sukhbaatar2015end}. $\dagger $ marks tasks where our error exceeds the paper by more than 5 points}{table.3}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces Per-task error comparison between our MemN2N (blue), our LSTM (orange), and the paper's MemN2N (dashed). Our model tracks the paper closely on most tasks; the main gaps are Tasks 3, 8, 16, and 20.}}{6}{figure.3}\protected@file@percent }
\newlabel{fig:baseline}{{3}{6}{Per-task error comparison between our MemN2N (blue), our LSTM (orange), and the paper's MemN2N (dashed). Our model tracks the paper closely on most tasks; the main gaps are Tasks 3, 8, 16, and 20}{figure.3}{}}
